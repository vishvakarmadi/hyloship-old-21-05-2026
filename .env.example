APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Google Sheets Integration
GOOGLE_SERVICE_ACCOUNT_JSON=updatesheettest-422805-cdf9ee7964cf.json

# Shopify Integration
SHOPIFY_APP_SECRET=your-shopify-app-secret-here

# Amazon Shipping Integration
AMAZON_REFRESH_TOKEN=your-amazon-refresh-token-here
AMAZON_CLIENT_ID=your-amazon-client-id-here
AMAZON_CLIENT_SECRET=your-amazon-client-secret-here

# Ekart Integration
EKART_CLIENT_ID=your-ekart-client-id-here
EKART_USERNAME=your-ekart-username-here
EKART_PASSWORD=your-ekart-password-here

# Shadowfax Integration
SHADOWFAX_TOKEN=your-shadowfax-token-here

# ParcelX / Blue Dart Access Token
PARCELX_ACCESS_TOKEN=your-parcelx-access-token-here

